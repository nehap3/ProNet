<div class="row">
    <div class="col-md-8 mx-auto">
        <h4 class="mb-4 fw-bold">Search results for "<%= query %>"</h4>

        <!-- Users Results -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom pt-3">
                <h5 class="fw-bold mb-0">People</h5>
            </div>
            <div class="list-group list-group-flush rounded-bottom">
                <% if (users.length > 0) { %>
                    <% users.forEach(resUser => { %>
                        <div class="list-group-item p-3 border-bottom">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <a href="/profile/<%= resUser._id %>">
                                        <img src="<%= resUser.profilePhoto %>" class="rounded-circle me-3 object-fit-cover shadow-sm" width="56" height="56">
                                    </a>
                                    <div>
                                        <h6 class="mb-0 fw-bold"><a href="/profile/<%= resUser._id %>" class="text-dark text-decoration-none hover-underline"><%= resUser.name %></a></h6>
                                        <p class="text-muted mb-0 small"><%= resUser.headline %></p>
                                        <% if (resUser.location) { %>
                                            <small class="text-muted"><%= resUser.location %></small>
                                        <% } %>
                                    </div>
                                </div>
                                <% if (user._id.toString() !== resUser._id.toString()) { %>
                                    <a href="/profile/<%= resUser._id %>" class="btn btn-outline-primary rounded-pill fw-bold px-4 py-1">View</a>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="p-4 text-muted">No people found.</div>
                <% } %>
            </div>
        </div>

        <!-- Jobs Results -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom pt-3">
                <h5 class="fw-bold mb-0">Jobs</h5>
            </div>
            <div class="list-group list-group-flush rounded-bottom">
                <% if (jobs.length > 0) { %>
                    <% jobs.forEach(job => { %>
                        <a href="/jobs/<%= job._id %>" class="list-group-item list-group-item-action p-3 border-bottom">
                            <div class="d-flex align-items-start">
                                <div class="bg-light p-2 rounded me-3 border d-flex justify-content-center align-items-center shadow-sm" style="width: 48px; height: 48px;">
                                    <i class="fas fa-briefcase text-secondary fs-5"></i>
                                </div>
                                <div>
                                    <h6 class="text-primary fw-bold mb-1"><%= job.title %></h6>
                                    <p class="mb-1 text-dark fw-bold"><%= job.company %></p>
                                    <small class="text-muted"><%= job.location %> • <%= job.type %></small>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                <% } else { %>
                    <div class="p-4 text-muted">No jobs found.</div>
                <% } %>
            </div>
        </div>
    </div>
</div>
