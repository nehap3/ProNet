<div class="row">
    <div class="col-md-8 mx-auto">
        <!-- Profile Header Card -->
        <div class="card shadow-sm border-0 mb-4 position-relative overflow-hidden">
            <!-- Cover Photo -->
            <div style="height: 200px; background-image: url('<%= profileUser.coverPhoto %>'); background-size: cover; background-position: center;"></div>
            
            <div class="card-body px-4 pt-0 pb-4 position-relative">
                <div class="d-flex justify-content-between align-items-end mb-3">
                    <!-- Profile Photo -->
                    <img src="<%= profileUser.profilePhoto %>" class="rounded-circle border border-4 border-white bg-white shadow-sm object-fit-cover" width="152" height="152" style="margin-top: -76px; z-index: 1; position: relative;">
                    
                    <!-- Action Buttons -->
                    <div class="mt-3">
                        <% if (user._id.toString() === profileUser._id.toString()) { %>
                            <a href="/profile/edit" class="btn btn-outline-secondary rounded-pill fw-bold">
                                <i class="fas fa-pencil-alt me-1"></i> Edit profile
                            </a>
                        <% } else { %>
                            <!-- Connection Logic -->
                            <% 
                                const isConnected = user.connections.includes(profileUser._id);
                                const hasSentRequest = user.sentRequests.includes(profileUser._id);
                                const hasPendingRequest = user.pendingRequests.includes(profileUser._id);
                            %>
                            
                            <div class="d-flex gap-2">
                                <a href="/messages?user=<%= profileUser._id %>" class="btn btn-primary rounded-pill fw-bold px-4">
                                    Message
                                </a>

                                <% if (isConnected) { %>
                                    <form action="/network/remove/<%= profileUser._id %>" method="POST">
                                        <button class="btn btn-outline-secondary rounded-pill fw-bold px-4">
                                            <i class="fas fa-user-check me-1"></i> Connected
                                        </button>
                                    </form>
                                <% } else if (hasSentRequest) { %>
                                    <button class="btn btn-secondary rounded-pill fw-bold px-4" disabled>Pending</button>
                                <% } else if (hasPendingRequest) { %>
                                    <form action="/network/accept/<%= profileUser._id %>" method="POST">
                                        <button class="btn btn-outline-primary rounded-pill fw-bold px-4">Accept</button>
                                    </form>
                                <% } else { %>
                                    <form action="/network/request/<%= profileUser._id %>" method="POST">
                                        <button class="btn btn-primary rounded-pill fw-bold px-4">
                                            <i class="fas fa-user-plus me-1"></i> Connect
                                        </button>
                                    </form>
                                <% } %>
                            </div>
                        <% } %>
                    </div>
                </div>

                <h3 class="fw-bold mb-1"><%= profileUser.name %></h3>
                <p class="fs-5 mb-2"><%= profileUser.headline %></p>
                <div class="text-muted small mb-2 d-flex align-items-center">
                    <% if (profileUser.location) { %>
                        <span class="me-2"><%= profileUser.location %></span> • 
                    <% } %>
                    <a href="#" class="ms-1 fw-bold text-primary text-decoration-none"><%= profileUser.connections.length %> connections</a>
                </div>

                <% if (profileUser.isOpenToWork) { %>
                    <div class="mt-3 p-3 bg-light rounded border" style="max-width: 350px;">
                        <h6 class="fw-bold mb-1">Open to work</h6>
                        <p class="small mb-0">Looking for new opportunities.</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- About Section -->
        <div class="card shadow-sm border-0 mb-4 p-4">
            <h5 class="fw-bold mb-3">About</h5>
            <p class="mb-0" style="white-space: pre-line;"><%= profileUser.about || "No about info provided." %></p>
        </div>

        <!-- Experience Section -->
        <div class="card shadow-sm border-0 mb-4 p-4">
            <h5 class="fw-bold mb-4">Experience</h5>
            <% if (profileUser.experience && profileUser.experience.length > 0) { %>
                <% profileUser.experience.forEach(exp => { %>
                    <div class="d-flex mb-4">
                        <div class="bg-light p-2 rounded d-flex justify-content-center align-items-center me-3 shadow-sm border" style="width: 48px; height: 48px;">
                            <i class="fas fa-building fs-4 text-secondary"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-0"><%= exp.role %></h6>
                            <p class="mb-1"><%= exp.company %></p>
                            <p class="text-muted small mb-2"><%= exp.duration %></p>
                            <p class="mb-0 small text-dark"><%= exp.description %></p>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="text-muted">No experience listed.</p>
            <% } %>
        </div>

        <!-- Education Section -->
        <div class="card shadow-sm border-0 mb-4 p-4">
            <h5 class="fw-bold mb-4">Education</h5>
            <% if (profileUser.education && profileUser.education.length > 0) { %>
                <% profileUser.education.forEach(edu => { %>
                    <div class="d-flex mb-4">
                        <div class="bg-light p-2 rounded d-flex justify-content-center align-items-center me-3 shadow-sm border" style="width: 48px; height: 48px;">
                            <i class="fas fa-university fs-4 text-secondary"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-0"><%= edu.college %></h6>
                            <p class="mb-1"><%= edu.degree %></p>
                            <p class="text-muted small mb-0"><%= edu.year %> | CGPA: <%= edu.cgpa %></p>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="text-muted">No education listed.</p>
            <% } %>
        </div>

        <!-- Skills Section -->
        <div class="card shadow-sm border-0 mb-4 p-4">
            <h5 class="fw-bold mb-3">Skills</h5>
            <% if (profileUser.skills && profileUser.skills.length > 0) { %>
                <div class="d-flex flex-wrap gap-2">
                    <% profileUser.skills.forEach(skill => { %>
                        <span class="badge rounded-pill border border-secondary text-dark py-2 px-3 fw-bold fs-6"><%= skill %></span>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="text-muted">No skills listed.</p>
            <% } %>
        </div>

    </div>
</div>
