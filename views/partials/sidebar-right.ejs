<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <h6 class="card-title fw-bold mb-3">Add to your feed</h6>
        
        <% if (typeof suggestions !== 'undefined' && suggestions.length > 0) { %>
            <% suggestions.forEach(function(suggestedUser) { %>
                <div class="d-flex mb-3">
                    <a href="/profile/<%= suggestedUser._id %>">
                        <img src="<%= suggestedUser.profilePhoto %>" class="rounded-circle me-2 object-fit-cover" width="48" height="48">
                    </a>
                    <div class="w-100">
                        <h6 class="mb-0 fs-6"><a href="/profile/<%= suggestedUser._id %>" class="text-dark text-decoration-none fw-bold hover-underline"><%= suggestedUser.name %></a></h6>
                        <p class="text-muted mb-1" style="font-size: 0.75rem;"><%= suggestedUser.headline %></p>
                        <form action="/network/request/<%= suggestedUser._id %>" method="POST">
                            <button type="submit" class="btn btn-outline-dark btn-sm rounded-pill fw-bold px-3 py-1 mt-1">
                                <i class="fas fa-plus me-1"></i> Follow
                            </button>
                        </form>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <p class="text-muted small">No new suggestions right now.</p>
        <% } %>
        
        <a href="/network" class="text-muted small text-decoration-none fw-bold d-block mt-3 hover-underline">View all recommendations <i class="fas fa-arrow-right"></i></a>
    </div>
</div>
