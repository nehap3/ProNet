<div class="card shadow-sm border-0 mb-4 profile-summary-card">
    <div class="card-img-top bg-secondary" style="height: 60px; background-image: url('<%= user.coverPhoto %>'); background-size: cover; background-position: center;"></div>
    <div class="card-body text-center pt-0 position-relative">
        <a href="/profile/<%= user._id %>">
            <img src="<%= user.profilePhoto %>" alt="<%= user.name %>" class="rounded-circle border border-2 border-white bg-white mt-n4 mb-2 object-fit-cover" width="72" height="72" style="margin-top: -36px;">
        </a>
        <h6 class="card-title mb-0 fw-bold"><a href="/profile/<%= user._id %>" class="text-dark text-decoration-none hover-underline"><%= user.name %></a></h6>
        <p class="text-muted small mb-3"><%= user.headline %></p>
        <hr>
        <div class="d-flex justify-content-between text-start small mb-1">
            <span class="text-muted">Connections</span>
            <span class="text-primary fw-bold"><%= user.connections.length %></span>
        </div>
        <div class="d-flex justify-content-between text-start small">
            <span class="text-muted">Grow your network</span>
        </div>
    </div>
    <div class="card-footer bg-white text-start">
        <a href="/jobs" class="text-dark text-decoration-none small fw-bold">
            <i class="fas fa-bookmark text-muted me-2"></i> My items
        </a>
    </div>
</div>
