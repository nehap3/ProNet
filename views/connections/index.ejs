<div class="row">
    <!-- Left column: Manage Network -->
    <div class="col-md-3 mb-4">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom-0 pt-3">
                <h6 class="fw-bold mb-0">Manage my network</h6>
            </div>
            <div class="list-group list-group-flush rounded-bottom">
                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center text-muted border-0 py-3">
                    <span><i class="fas fa-user-friends me-3 text-secondary fs-5 align-middle"></i> Connections</span>
                    <span class="badge bg-light text-dark rounded-pill fw-normal fs-6"><%= user.connections.length %></span>
                </a>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="col-md-9">
        
        <!-- Pending Requests -->
        <% if (user.pendingRequests.length > 0) { %>
            <div class="card shadow-sm border-0 mb-4 p-3">
                <div class="d-flex justify-content-between align-items-center mb-3 px-2 border-bottom pb-2">
                    <h5 class="fw-bold mb-0">Invitations</h5>
                </div>
                
                <% user.pendingRequests.forEach(reqUser => { %>
                    <div class="d-flex align-items-center justify-content-between p-2 border-bottom">
                        <div class="d-flex align-items-center">
                            <a href="/profile/<%= reqUser._id %>">
                                <img src="<%= reqUser.profilePhoto %>" class="rounded-circle me-3 object-fit-cover shadow-sm" width="72" height="72">
                            </a>
                            <div>
                                <h6 class="mb-0 fs-5"><a href="/profile/<%= reqUser._id %>" class="text-dark text-decoration-none fw-bold hover-underline"><%= reqUser.name %></a></h6>
                                <p class="text-muted mb-0"><%= reqUser.headline %></p>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <form action="/network/reject/<%= reqUser._id %>" method="POST">
                                <button type="submit" class="btn btn-outline-secondary fw-bold rounded-pill px-4 py-2">Ignore</button>
                            </form>
                            <form action="/network/accept/<%= reqUser._id %>" method="POST">
                                <button type="submit" class="btn btn-outline-primary fw-bold rounded-pill px-4 py-2">Accept</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <!-- People you may know (Suggestions) -->
        <div class="card shadow-sm border-0 p-3 mb-4">
            <h5 class="fw-bold mb-4 px-2">People you may know</h5>
            
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                <% if (suggestions.length > 0) { %>
                    <% suggestions.forEach(sugg => { %>
                        <div class="col">
                            <div class="card h-100 border text-center shadow-sm hover-shadow transition-all profile-summary-card position-relative overflow-hidden">
                                <div class="bg-secondary" style="height: 60px; background-image: url('<%= sugg.coverPhoto %>'); background-size: cover; background-position: center;"></div>
                                <div class="card-body pt-0 px-3 pb-3 d-flex flex-column">
                                    <div class="mb-3 mt-n4">
                                        <a href="/profile/<%= sugg._id %>">
                                            <img src="<%= sugg.profilePhoto %>" class="rounded-circle border border-2 border-white bg-white object-fit-cover shadow-sm" width="96" height="96">
                                        </a>
                                    </div>
                                    <h6 class="card-title fw-bold fs-5 mb-1 text-truncate"><a href="/profile/<%= sugg._id %>" class="text-dark text-decoration-none hover-underline"><%= sugg.name %></a></h6>
                                    <p class="card-text text-muted small mb-4" style="height: 40px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;"><%= sugg.headline %></p>
                                    
                                    <form action="/network/request/<%= sugg._id %>" method="POST" class="mt-auto w-100">
                                        <button type="submit" class="btn btn-outline-primary rounded-pill fw-bold w-100">
                                            Connect
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12 text-center py-4 text-muted">
                        No suggestions right now.
                    </div>
                <% } %>
            </div>
        </div>

    </div>
</div>
