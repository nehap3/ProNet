<div class="row">
    <div class="col-md-3 mb-4">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom-0 pt-3">
                <h6 class="fw-bold mb-0"><i class="fas fa-bookmark text-muted me-2"></i> My jobs</h6>
            </div>
            <div class="list-group list-group-flush rounded-bottom">
                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center text-muted border-0 py-3">
                    <span>Applied jobs</span>
                    <span class="badge bg-light text-dark rounded-pill fw-normal fs-6"><%= user.appliedJobs.length %></span>
                </a>
                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center text-muted border-0 py-3">
                    <span>Saved jobs</span>
                    <span class="badge bg-light text-dark rounded-pill fw-normal fs-6"><%= user.savedJobs.length %></span>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="card shadow-sm border-0 p-4 mb-4">
            <h5 class="fw-bold mb-3">Search for your next job</h5>
            <form action="/jobs" method="GET" class="row g-2">
                <div class="col-md-5">
                    <input type="text" name="location" class="form-control form-control-lg fs-6" placeholder="City, state, or zip code" value="<%= query.location || '' %>">
                </div>
                <div class="col-md-4">
                    <select name="type" class="form-select form-select-lg fs-6">
                        <option value="">Any job type</option>
                        <option value="Remote" <%= query.type === 'Remote' ? 'selected' : '' %>>Remote</option>
                        <option value="Hybrid" <%= query.type === 'Hybrid' ? 'selected' : '' %>>Hybrid</option>
                        <option value="On-site" <%= query.type === 'On-site' ? 'selected' : '' %>>On-site</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold fs-6">Search</button>
                </div>
            </form>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <% if (jobs.length > 0) { %>
                    <ul class="list-group list-group-flush rounded">
                        <% jobs.forEach(job => { %>
                            <a href="/jobs/<%= job._id %>" class="list-group-item list-group-item-action p-4 border-bottom">
                                <div class="d-flex align-items-start">
                                    <div class="bg-light p-3 rounded me-3 border d-flex justify-content-center align-items-center shadow-sm" style="width: 56px; height: 56px;">
                                        <i class="fas fa-briefcase text-secondary fs-4"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h5 class="text-primary fw-bold mb-1"><%= job.title %></h5>
                                        <h6 class="mb-1 text-dark"><%= job.company %></h6>
                                        <p class="text-muted small mb-1"><%= job.location %> • <%= job.type %></p>
                                        <div class="d-flex align-items-center mt-2">
                                            <span class="badge bg-success-subtle text-success me-2"><i class="fas fa-money-bill-wave me-1"></i><%= job.salary %></span>
                                            <small class="text-muted"><%= new Date(job.createdAt).toLocaleDateString() %></small>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <div class="p-5 text-center text-muted">
                        <img src="/images/jobs-empty.svg" alt="No jobs" onerror="this.style.display='none'" width="150" class="mb-3">
                        <h4 class="fw-bold">No jobs found matching your criteria</h4>
                        <p>Try adjusting your search filters or check back later.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
