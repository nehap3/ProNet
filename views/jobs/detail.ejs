<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card shadow-sm border-0 mb-4 p-4">
            <div class="d-flex align-items-start mb-4 border-bottom pb-4">
                <div class="bg-light p-3 rounded me-4 border d-flex justify-content-center align-items-center shadow-sm" style="width: 80px; height: 80px;">
                    <i class="fas fa-briefcase text-secondary fa-2x"></i>
                </div>
                <div class="flex-grow-1">
                    <h2 class="fw-bold mb-1"><%= job.title %></h2>
                    <h5 class="text-dark mb-1"><%= job.company %></h5>
                    <p class="text-muted mb-2"><%= job.location %> • <%= job.type %> • Posted <%= new Date(job.createdAt).toLocaleDateString() %></p>
                    <div class="d-flex align-items-center mb-3">
                        <span class="badge bg-success-subtle text-success px-3 py-2 fw-bold fs-6 me-2"><i class="fas fa-money-bill-wave me-1"></i><%= job.salary %></span>
                        <span class="badge bg-secondary-subtle text-secondary px-3 py-2 fw-bold fs-6"><i class="fas fa-users me-1"></i><%= job.applicants.length %> applicants</span>
                    </div>

                    <div class="d-flex gap-2">
                        <% if (hasApplied) { %>
                            <button class="btn btn-success fw-bold rounded-pill px-4" disabled><i class="fas fa-check me-2"></i>Applied</button>
                        <% } else { %>
                            <form action="/jobs/apply/<%= job._id %>" method="POST">
                                <button type="submit" class="btn btn-primary fw-bold rounded-pill px-4">Apply Now</button>
                            </form>
                        <% } %>

                        <% if (hasSaved) { %>
                            <button class="btn btn-outline-secondary fw-bold rounded-pill px-4" disabled><i class="fas fa-bookmark text-muted me-2"></i>Saved</button>
                        <% } else { %>
                            <form action="/jobs/save/<%= job._id %>" method="POST">
                                <button type="submit" class="btn btn-outline-secondary fw-bold rounded-pill px-4"><i class="far fa-bookmark me-2"></i>Save</button>
                            </form>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <h5 class="fw-bold mb-3">About the job</h5>
                <p style="white-space: pre-line;" class="text-dark fs-6 lh-lg"><%= job.description %></p>
            </div>

            <div class="mb-4">
                <h5 class="fw-bold mb-3">Requirements</h5>
                <p style="white-space: pre-line;" class="text-dark fs-6 lh-lg"><%= job.requirements %></p>
            </div>

            <div class="mt-4 pt-4 border-top">
                <h6 class="fw-bold mb-3">Posted by</h6>
                <div class="d-flex align-items-center">
                    <a href="/profile/<%= job.postedBy._id %>">
                        <img src="<%= job.postedBy.profilePhoto %>" class="rounded-circle me-3 object-fit-cover shadow-sm" width="56" height="56">
                    </a>
                    <div>
                        <h6 class="mb-0 fw-bold"><a href="/profile/<%= job.postedBy._id %>" class="text-dark text-decoration-none hover-underline"><%= job.postedBy.name %></a></h6>
                        <p class="text-muted small mb-0"><%= job.postedBy.headline %></p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
